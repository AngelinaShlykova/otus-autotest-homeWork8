<con:soapui-project id="wishlist-api-tests" activeEnvironment="Default" name="Wishlist API Tests" resourceRoot="" soapui-version="5.7.0" abortOnError="false" runType="SEQUENTIAL" xmlns:con="http://eviware.com/soapui/config">
  <con:settings/>
  <con:interface xsi:type="con:RestService" wadlVersion="http://wadl.dev.java.net/2009/02" id="wishlist-rest-api" name="Wishlist REST API" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <con:settings/>
    <con:definitionCache/>
    <con:endpoints>
      <con:endpoint>http://api.wishlist.otus.kartushin.su</con:endpoint>
    </con:endpoints>
    <con:resource id="auth-resource" name="/api/auth" path="/api/auth">
      <con:settings/>
      <con:parameters/>
      <con:method id="login-method" name="Login" method="POST">
        <con:settings/>
        <con:parameters/>
        <con:representation type="REQUEST">
          <con:mediaType>application/json</con:mediaType>
          <con:params/>
        </con:representation>
        <con:request id="login-request" name="Login Request" mediaType="application/json">
          <con:settings/>
          <con:endpoint>http://api.wishlist.otus.kartushin.su</con:endpoint>
          <con:parameters/>
          <con:representation type="RESPONSE">
            <con:mediaType>application/json</con:mediaType>
            <con:status>200</con:status>
            <con:params/>
            <con:element>response</con:element>
          </con:representation>
          <con:body>{"username": "testuser", "password": "password123"}</con:body>
        </con:request>
      </con:method>
    </con:resource>
    <con:resource id="wishlist-resource" name="/api/wishlists" path="/api/wishlists">
      <con:settings/>
      <con:parameters/>
      <con:method id="create-wishlist-method" name="Create Wishlist" method="POST">
        <con:settings/>
        <con:parameters/>
        <con:representation type="REQUEST">
          <con:mediaType>application/json</con:mediaType>
          <con:params/>
        </con:representation>
        <con:request id="create-wishlist-request" name="Create Wishlist Request" mediaType="application/json">
          <con:settings/>
          <con:endpoint>http://api.wishlist.otus.kartushin.su</con:endpoint>
          <con:parameters/>
          <con:representation type="RESPONSE">
            <con:mediaType>application/json</con:mediaType>
            <con:status>200</con:status>
            <con:params/>
            <con:element>response</con:element>
          </con:representation>
          <con:body>{"title": "My Wishlist", "description": "Test wishlist"}</con:body>
          <con:headers>
            <con:entry>
              <con:key>Authorization</con:key>
              <con:value>Bearer ${#Project#token}</con:value>
            </con:entry>
            <con:entry>
              <con:key>Content-Type</con:key>
              <con:value>application/json</con:value>
            </con:entry>
          </con:headers>
        </con:request>
      </con:method>
    </con:resource>
  </con:interface>
  <con:testSuite id="wishlist-test-suite" name="Wishlist API Test Suite">
    <con:settings/>
    <con:runType>SEQUENTIAL</con:runType>
    <con:testCase id="auth-test-case" name="Authentication Tests" failOnError="true" failTestCaseOnErrors="true" keepSession="true" maxResults="0" searchProperties="true" timeout="0">
      <con:settings/>
      <con:testStep id="login-step" type="restrequest" name="Login">
        <con:settings/>
        <con:config xsi:type="con:RestRequestStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
          <con:restRequest name="Login" id="login-request" serviceInterface="Wishlist REST API" resourceInterface="auth-resource" methodInterface="login-method">
            <con:settings/>
            <con:endpoint>http://api.wishlist.otus.kartushin.su</con:endpoint>
            <con:body>{"username": "testuser", "password": "password123"}</con:body>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:testStep id="extract-token-step" type="groovy" name="Extract Token">
        <con:settings/>
        <con:config>
          <script>
import groovy.json.JsonSlurper

def response = context.expand('${Login#Response}')
def json = new JsonSlurper().parseText(response)
if (json.token) {
    project.setPropertyValue("token", json.token)
    log.info("Token extracted: " + json.token)
} else {
    log.error("Token not found in response")
}
          </script>
        </con:config>
      </con:testStep>
      <con:assertion type="Valid HTTP Status Codes" name="Valid Status Code">
        <con:configuration>
          <codes>200</codes>
        </con:configuration>
      </con:assertion>
      <con:assertion type="JsonPath Match" name="Has Token">
        <con:configuration>
          <path>$.token</path>
          <content>${#Project#token}</content>
          <allowWildcards>false</allowWildcards>
          <ignoreNamspaceDifferences>false</ignoreNamspaceDifferences>
          <ignoreComments>false</ignoreComments>
        </con:configuration>
      </con:assertion>
    </con:testCase>
    <con:testCase id="wishlist-test-case" name="Wishlist CRUD Tests" failOnError="true" failTestCaseOnErrors="true" keepSession="true" maxResults="0" searchProperties="true" timeout="0">
      <con:settings/>
      <con:testStep id="create-wishlist-step" type="restrequest" name="Create Wishlist">
        <con:settings/>
        <con:config xsi:type="con:RestRequestStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
          <con:restRequest name="Create Wishlist" id="create-wishlist-request" serviceInterface="Wishlist REST API" resourceInterface="wishlist-resource" methodInterface="create-wishlist-method">
            <con:settings/>
            <con:endpoint>http://api.wishlist.otus.kartushin.su</con:endpoint>
            <con:body>{"title": "My Wishlist", "description": "Test wishlist"}</con:body>
            <con:headers>
              <con:entry>
                <con:key>Authorization</con:key>
                <con:value>Bearer ${#Project#token}</con:value>
              </con:entry>
            </con:headers>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:assertion type="Valid HTTP Status Codes" name="Valid Status Code">
        <con:configuration>
          <codes>200,201</codes>
        </con:configuration>
      </con:assertion>
      <con:assertion type="JsonPath Match" name="Has ID">
        <con:configuration>
          <path>$.id</path>
          <content/>
          <allowWildcards>false</allowWildcards>
          <ignoreNamspaceDifferences>false</ignoreNamspaceDifferences>
          <ignoreComments>false</ignoreComments>
        </con:configuration>
      </con:assertion>
    </con:testCase>
    <con:testCase id="negative-test-case" name="Negative Tests" failOnError="false" failTestCaseOnErrors="true" keepSession="true" maxResults="0" searchProperties="true" timeout="0">
      <con:settings/>
      <con:testStep id="create-without-auth-step" type="restrequest" name="Create Wishlist Without Auth">
        <con:settings/>
        <con:config xsi:type="con:RestRequestStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
          <con:restRequest name="Create Wishlist No Auth" id="create-wishlist-request" serviceInterface="Wishlist REST API" resourceInterface="wishlist-resource" methodInterface="create-wishlist-method">
            <con:settings/>
            <con:endpoint>http://api.wishlist.otus.kartushin.su</con:endpoint>
            <con:body>{"title": "No Auth Wishlist"}</con:body>
            <con:headers/>
          </con:restRequest>
        </con:config>
      </con:testStep>
      <con:assertion type="Valid HTTP Status Codes" name="Expect 401 or 403">
        <con:configuration>
          <codes>401,403</codes>
        </con:configuration>
      </con:assertion>
    </con:testCase>
  </con:testSuite>
  <con:properties>
    <con:property>
      <con:name>token</con:name>
      <con:value/>
    </con:property>
    <con:property>
      <con:name>baseUrl</con:name>
      <con:value>http://api.wishlist.otus.kartushin.su</con:value>
    </con:property>
  </con:properties>
  <con:wssContainer/>
  <con:oAuth2ProfileContainer/>
  <con:oAuth1ProfileContainer/>
  <con:sensitiveInformation/>
</con:soapui-project>
